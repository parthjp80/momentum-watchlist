# ── Copy this to .env and fill in your values ──────────────────────────────
# Never commit .env to version control.
# No WATCHLIST variable needed — the program discovers stocks automatically.

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email settings ───────────────────────────────────────────────────────────
EMAIL_FROM=watchlist@yourdomain.com
EMAIL_TO=you@yourdomain.com              # comma-separated for multiple recipients

# Gmail (use an App Password — NOT your real password):
# myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Outlook / Office 365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# Self-hosted Mailcow on TrueNAS:
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587

# ── Screening parameters ─────────────────────────────────────────────────────
# Minimum stock price to consider (filters out penny stocks)
MIN_PRICE=5

# Minimum 3-month average daily volume (filters out illiquid names)
MIN_AVG_VOLUME=500000

# Maximum candidates to score after liquidity filter (higher = slower but more coverage)
MAX_CANDIDATES=200

# How many stocks to include in the email
TOP_N=10

# ── Signal weights (should sum to ~100) ─────────────────────────────────────
W_SHARPE=20
W_VOLUME=18
W_BREAKOUT=15
W_EMA=15
W_ATR=12
W_TAPE=10
W_PATTERN=10
